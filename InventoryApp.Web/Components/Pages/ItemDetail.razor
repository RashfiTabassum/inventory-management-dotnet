@page "/items/{Id:int}"
@rendermode InteractiveServer
@inject ItemService ItemService
@inject CustomFieldService CustomFieldService
@inject InventoryService InventoryService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>@(_item?.Name ?? "Item")</PageTitle>

@if (_item == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <a href="/inventories/@_item.InventoryId" class="btn btn-secondary btn-sm">
            ← Back to Inventory
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>@_item.Name</h3>
        @if (_hasWriteAccess)
        {
            <div>
                @if (!_isEditing)
                {
                    <button class="btn btn-primary btn-sm"
                            @onclick="StartEdit">
                        Edit
                    </button>
                    <button class="btn btn-danger btn-sm ms-2"
                            @onclick="HandleDelete">
                        Delete
                    </button>
                }
            </div>
        }
    </div>

    @if (_isEditing)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">Name *</label>
                    <input class="form-control" @bind="_editName" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Custom ID</label>
                    <input class="form-control" @bind="_editCustomId" />
                </div>

                @foreach (var field in _customFields)
                {
                    <div class="mb-2">
                        <label class="form-label" title="@field.Description">
                            @field.Title
                            @if (!string.IsNullOrEmpty(field.Description))
                            {
                                <span class="text-muted ms-1"
                                      title="@field.Description">ⓘ</span>
                            }
                        </label>

                        @if (field.FieldType == CustomFieldType.SingleLine)
                        {
                            <input class="form-control"
                                   value="@GetFieldValue(field.Id)"
                                   @oninput="e => SetFieldValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                        }
                        else if (field.FieldType == CustomFieldType.MultiLine)
                        {
                            <textarea class="form-control" rows="3"
                                      @oninput="e => SetFieldValue(field.Id, e.Value?.ToString() ?? string.Empty)">@GetFieldValue(field.Id)</textarea>
                        }
                        else if (field.FieldType == CustomFieldType.Numeric)
                        {
                            <input type="number" class="form-control"
                                   value="@GetFieldValue(field.Id)"
                                   @oninput="e => SetFieldValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                        }
                        else if (field.FieldType == CustomFieldType.DocumentLink)
                        {
                            <input type="url" class="form-control"
                                   placeholder="https://..."
                                   value="@GetFieldValue(field.Id)"
                                   @oninput="e => SetFieldValue(field.Id, e.Value?.ToString() ?? string.Empty)" />
                        }
                        else if (field.FieldType == CustomFieldType.Boolean)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox"
                                       checked="@(GetFieldValue(field.Id) == "true")"
                                       @onchange="e => SetFieldValue(field.Id, (e.Value?.ToString() ?? string.Empty).ToLower())" />
                                <label class="form-check-label">@field.Title</label>
                            </div>
                        }
                    </div>
                }

                <button class="btn btn-success" @onclick="HandleSave">
                    Save
                </button>
                <button class="btn btn-secondary ms-2"
                        @onclick="CancelEdit">
                    Cancel
                </button>
                @if (_saveError != null)
                {
                    <div class="alert alert-danger mt-2">@_saveError</div>
                }
            </div>
        </div>
    }
    else
    {
        <table class="table table-bordered">
            <tbody>
                <tr>
                    <th style="width:200px">Custom ID</th>
                    <td>@_item.CustomId</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>@_item.Name</td>
                </tr>
                <tr>
                    <th>Created By</th>
                    <td>@_item.CreatedBy.Email</td>
                </tr>
                <tr>
                    <th>Created At</th>
                    <td>@_item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                </tr>

                @foreach (var field in _customFields)
                {
                    <tr>
                        <th>@field.Title</th>
                        <td>
                            @if (field.FieldType == CustomFieldType.Boolean)
                            {
                                @(GetFieldValue(field.Id) == "true" ? "✓ Yes" : "✗ No")
                            }
                            else if (field.FieldType == CustomFieldType.DocumentLink)
                            {
                                var url = GetFieldValue(field.Id);
                                @if (!string.IsNullOrEmpty(url))
                                {
                                    <a href="@url" target="_blank">@url</a>
                                }
                            }
                            else
                            {
                                @GetFieldValue(field.Id)
                            }
                        </td>
                    </tr>
                }

                <tr>
                    <th>Likes</th>
                    <td>
                        @_item.Likes.Count
                        @if (_currentUserId != null && !_hasLiked)
                        {
                            <button class="btn btn-sm btn-outline-primary ms-2"
                                    @onclick="HandleLike">
                                ♥ Like
                            </button>
                        }
                        else if (_hasLiked)
                        {
                            <span class="ms-2 text-primary">♥ Liked</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Item? _item;
    private List<CustomField> _customFields = new();
    private Dictionary<int, string> _fieldValues = new();
    private Dictionary<int, string> _editFieldValues = new();
    private bool _hasWriteAccess = false;
    private bool _isEditing = false;
    private bool _hasLiked = false;
    private string? _currentUserId;
    private string _editName = string.Empty;
    private string _editCustomId = string.Empty;
    private string? _saveError;

    protected override async Task OnInitializedAsync()
    {
        await LoadItemAsync();

        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var user = authState.User;

        _currentUserId = user.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (_currentUserId != null && _item != null)
        {
            var isAdmin = user.IsInRole("Admin");
            var isOwner = _item.CreatedById == _currentUserId;

            _hasWriteAccess = isAdmin || isOwner ||
                await ItemService.HasWriteAccessAsync(
                    _item.InventoryId, _currentUserId);

            _hasLiked = _item.Likes
                .Any(l => l.UserId == _currentUserId);
        }
    }

    private async Task LoadItemAsync()
    {
        _item = await ItemService.GetByIdAsync(Id);
        if (_item == null)
        {
            Navigation.NavigateTo("/inventories");
            return;
        }

        _customFields = await CustomFieldService
            .GetByInventoryAsync(_item.InventoryId);

        _fieldValues = await CustomFieldService
            .GetFieldValuesAsync(Id);
    }

    private string GetFieldValue(int fieldId)
    {
        return _fieldValues.TryGetValue(fieldId, out var val)
            ? val : string.Empty;
    }

    private void SetFieldValue(int fieldId, string value)
    {
        _editFieldValues[fieldId] = value;
    }

    private void StartEdit()
    {
        _editName = _item!.Name;
        _editCustomId = _item.CustomId;
        _editFieldValues = new Dictionary<int, string>(_fieldValues);
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _saveError = null;
        _editFieldValues.Clear();
    }

    private async Task HandleSave()
    {
        if (string.IsNullOrWhiteSpace(_editName))
        {
            _saveError = "Name is required.";
            return;
        }

        _item!.Name = _editName.Trim();
        _item.CustomId = _editCustomId.Trim();

        var success = await ItemService.UpdateAsync(_item);
        if (!success)
        {
            _saveError = "Failed to save. Please try again.";
            return;
        }

        foreach (var kv in _editFieldValues)
        {
            await CustomFieldService.SaveFieldValueAsync(
                Id, kv.Key, kv.Value);
        }

        _isEditing = false;
        _saveError = null;
        await LoadItemAsync();
    }

    private async Task HandleDelete()
    {
        if (_currentUserId == null) return;

        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var isAdmin = authState.User.IsInRole("Admin");

        var success = await ItemService
            .DeleteAsync(Id, _currentUserId, isAdmin);

        if (success)
            Navigation.NavigateTo(
                $"/inventories/{_item!.InventoryId}");
    }

    private async Task HandleLike()
    {
        if (_currentUserId == null) return;

        var liked = await ItemService
            .ToggleLikeAsync(Id, _currentUserId);

        _hasLiked = liked;
        await LoadItemAsync();
    }
}