@page "/profile"
@rendermode InteractiveServer
@inject InventoryService InventoryService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject InventoryApp.Web.Services.SalesforceService SalesforceService

<PageTitle>My Profile</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h3>My Profile</h3>
                <p class="text-muted mb-0">@context.User.Identity!.Name</p>
            </div>
            <button class="btn btn-outline-primary btn-sm"
                    @onclick="OpenCrmModal">
                ☁ Register in CRM (Salesforce)
            </button>
        </div>

        <hr />

        <!-- Owned Inventories -->
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5>My Inventories</h5>
            <div class="d-flex gap-2">
                @if (_selectedOwnedIds.Any())
                {
                    <button class="btn btn-danger btn-sm"
                            @onclick="HandleDeleteSelected">
                        Delete Selected (@_selectedOwnedIds.Count)
                    </button>
                }
                <a href="/inventories/create" class="btn btn-primary btn-sm">
                    + New Inventory
                </a>
            </div>
        </div>

        <div class="mb-2">
            <input class="form-control form-control-sm" style="max-width:300px"
                   placeholder="Filter by name..."
                   @oninput="OnOwnedFilterChanged" />
        </div>

        @if (_ownedInventories == null)
        {
            <p>Loading...</p>
        }
        else if (_ownedInventories.Count == 0)
        {
            <p class="text-muted">You haven't created any inventories yet.</p>
        }
        else
        {
            <table class="table table-hover table-bordered mb-4">
                <thead>
                    <tr>
                        <th style="width:40px">
                            <input type="checkbox"
                                   @onchange="ToggleSelectAllOwned" />
                        </th>
                        <th @onclick='() => SortOwned("name")' 
                            style="cursor:pointer">
                            Name @SortIcon(_ownedSortField, "name", _ownedSortAsc)
                        </th>
                        <th @onclick='() => SortOwned("category")' 
                            style="cursor:pointer">
                            Category @SortIcon(_ownedSortField, "category", _ownedSortAsc)
                        </th>
                        <th @onclick='() => SortOwned("date")' 
                            style="cursor:pointer">
                            Created @SortIcon(_ownedSortField, "date", _ownedSortAsc)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in _ownedInventories)
                    {
                        <tr class="@(_selectedOwnedIds.Contains(inv.Id) ? "table-active" : "")"
                            style="cursor:pointer">
                            <td @onclick:stopPropagation="true">
                                <input type="checkbox"
                                       checked="@_selectedOwnedIds.Contains(inv.Id)"
                                       @onchange="() => ToggleSelectOwned(inv.Id)" />
                            </td>
                            <td @onclick="() => GoToInventory(inv.Id)">@inv.Name</td>
                            <td @onclick="() => GoToInventory(inv.Id)">@inv.Category</td>
                            <td @onclick="() => GoToInventory(inv.Id)">@inv.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <hr />

        <!-- Inventories with Write Access -->
        <h5 class="mb-2">Inventories I Can Edit</h5>

        <div class="mb-2">
            <input class="form-control form-control-sm" style="max-width:300px"
                   placeholder="Filter by name..."
                   @oninput="OnAccessFilterChanged" />
        </div>

        @if (_accessInventories == null)
        {
            <p>Loading...</p>
        }
        else if (_accessInventories.Count == 0)
        {
            <p class="text-muted">No inventories shared with you yet.</p>
        }
        else
        {
            <table class="table table-hover table-bordered">
                <thead>
                    <tr>
                        <th @onclick='() => SortAccess("name")' 
                            style="cursor:pointer">
                            Name @SortIcon(_accessSortField, "name", _accessSortAsc)
                        </th>
                        <th @onclick='() => SortAccess("owner")' 
                            style="cursor:pointer">
                            Owner @SortIcon(_accessSortField, "owner", _accessSortAsc)
                        </th>
                        <th @onclick='() => SortAccess("category")' 
                            style="cursor:pointer">
                            Category @SortIcon(_accessSortField, "category", _accessSortAsc)
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var inv in _accessInventories)
                    {
                        <tr @onclick="() => GoToInventory(inv.Id)"
                            style="cursor:pointer">
                            <td>@inv.Name</td>
                            <td>@inv.Owner.Email</td>
                            <td>@inv.Category</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </Authorized>
    <NotAuthorized>
        <p>Please <a href="/account/login">log in</a> to view your profile.</p>
    </NotAuthorized>
</AuthorizeView>

<!-- ── Salesforce CRM Modal ─────────────────────────────────────────── -->
@if (_showCrmModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Register in CRM (Salesforce)</h5>
                    <button type="button" class="btn-close"
                            @onclick="() => _showCrmModal = false"></button>
                </div>
                <div class="modal-body">
                    @if (_crmSuccess)
                    {
                        <div class="alert alert-success">
                            <strong>Done!</strong> Account and Contact created in Salesforce.
                            <br /><small>Account ID: @_crmAccountId</small><br />
                            <small>Contact ID: @_crmContactId</small>
                        </div>
                    }
                    else
                    {
                        @if (_crmError != null)
                        {
                            <div class="alert alert-danger">@_crmError</div>
                        }
                        <div class="mb-3 row">
                            <div class="col">
                                <label class="form-label">First Name *</label>
                                <input class="form-control" @bind="_crmFirstName" />
                            </div>
                            <div class="col">
                                <label class="form-label">Last Name *</label>
                                <input class="form-control" @bind="_crmLastName" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Phone</label>
                            <input class="form-control" @bind="_crmPhone" placeholder="+1 555 000 0000" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Company / Account Name *</label>
                            <input class="form-control" @bind="_crmCompany" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Industry</label>
                            <select class="form-select" @bind="_crmIndustry">
                                <option value="">— select —</option>
                                <option>Technology</option>
                                <option>Finance</option>
                                <option>Healthcare</option>
                                <option>Education</option>
                                <option>Retail</option>
                                <option>Manufacturing</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Country</label>
                            <input class="form-control" @bind="_crmCountry" placeholder="e.g. United States" />
                        </div>
                    }
                </div>
                @if (!_crmSuccess)
                {
                    <div class="modal-footer">
                        <button class="btn btn-secondary"
                                @onclick="() => _showCrmModal = false">Cancel</button>
                        <button class="btn btn-primary"
                                @onclick="SubmitCrmAsync"
                                disabled="@_crmSubmitting">
                            @(_crmSubmitting ? "Sending to Salesforce…" : "Create Account & Contact")
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private List<Inventory>? _ownedInventories;
    private List<Inventory>? _accessInventories;
    private List<Inventory> _allOwnedInventories = new();
    private List<Inventory> _allAccessInventories = new();
    private string? _currentUserId;

    private string _ownedSortField = "date";
    private bool _ownedSortAsc = false;
    private string _accessSortField = "name";
    private bool _accessSortAsc = true;
    private string _ownedFilter = string.Empty;
    private string _accessFilter = string.Empty;
    private HashSet<int> _selectedOwnedIds = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var user = authState.User;

        _currentUserId = user.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (_currentUserId == null)
        {
            Navigation.NavigateTo("/account/login");
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _allOwnedInventories = await InventoryService
            .GetOwnedByUserAsync(_currentUserId!);
        _allAccessInventories = await InventoryService
            .GetInventoriesWithWriteAccessAsync(_currentUserId!);

        ApplyFiltersAndSort();
    }

    private void ApplyFiltersAndSort()
    {
        var owned = _allOwnedInventories.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_ownedFilter))
            owned = owned.Where(i => i.Name.Contains(_ownedFilter, StringComparison.OrdinalIgnoreCase));
        _ownedInventories = ApplySortOwned(owned.ToList());

        var access = _allAccessInventories.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(_accessFilter))
            access = access.Where(i => i.Name.Contains(_accessFilter, StringComparison.OrdinalIgnoreCase));
        _accessInventories = ApplySortAccess(access.ToList());
    }

    private void OnOwnedFilterChanged(ChangeEventArgs e)
    {
        _ownedFilter = e.Value?.ToString() ?? string.Empty;
        _selectedOwnedIds.Clear();
        ApplyFiltersAndSort();
    }

    private void OnAccessFilterChanged(ChangeEventArgs e)
    {
        _accessFilter = e.Value?.ToString() ?? string.Empty;
        ApplyFiltersAndSort();
    }

    private void SortOwned(string field)
    {
        if (_ownedSortField == field)
            _ownedSortAsc = !_ownedSortAsc;
        else
        {
            _ownedSortField = field;
            _ownedSortAsc = true;
        }
        ApplyFiltersAndSort();
    }

    private void SortAccess(string field)
    {
        if (_accessSortField == field)
            _accessSortAsc = !_accessSortAsc;
        else
        {
            _accessSortField = field;
            _accessSortAsc = true;
        }
        ApplyFiltersAndSort();
    }

    private List<Inventory> ApplySortOwned(List<Inventory> list)
    {
        return _ownedSortField switch
        {
            "name" => _ownedSortAsc
                ? list.OrderBy(i => i.Name).ToList()
                : list.OrderByDescending(i => i.Name).ToList(),
            "category" => _ownedSortAsc
                ? list.OrderBy(i => i.Category).ToList()
                : list.OrderByDescending(i => i.Category).ToList(),
            _ => _ownedSortAsc
                ? list.OrderBy(i => i.CreatedAt).ToList()
                : list.OrderByDescending(i => i.CreatedAt).ToList()
        };
    }

    private List<Inventory> ApplySortAccess(List<Inventory> list)
    {
        return _accessSortField switch
        {
            "owner" => _accessSortAsc
                ? list.OrderBy(i => i.Owner.Email).ToList()
                : list.OrderByDescending(i => i.Owner.Email).ToList(),
            "category" => _accessSortAsc
                ? list.OrderBy(i => i.Category).ToList()
                : list.OrderByDescending(i => i.Category).ToList(),
            _ => _accessSortAsc
                ? list.OrderBy(i => i.Name).ToList()
                : list.OrderByDescending(i => i.Name).ToList()
        };
    }

    private string SortIcon(string currentField, string thisField, bool asc)
    {
        if (currentField != thisField) return "↕";
        return asc ? "↑" : "↓";
    }

    private void ToggleSelectOwned(int id)
    {
        if (!_selectedOwnedIds.Remove(id))
            _selectedOwnedIds.Add(id);
    }

    private void ToggleSelectAllOwned(ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false) && _ownedInventories != null)
            _selectedOwnedIds = _ownedInventories.Select(i => i.Id).ToHashSet();
        else
            _selectedOwnedIds.Clear();
    }

    private async Task HandleDeleteSelected()
    {
        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var isAdmin = authState.User.IsInRole("Admin");

        foreach (var id in _selectedOwnedIds.ToList())
        {
            await InventoryService.DeleteAsync(id, _currentUserId!, isAdmin);
        }

        _selectedOwnedIds.Clear();
        await LoadDataAsync();
    }

    private async Task HandleDelete(int inventoryId)
    {
        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var isAdmin = authState.User.IsInRole("Admin");

        var success = await InventoryService
            .DeleteAsync(inventoryId, _currentUserId!, isAdmin);

        if (success)
            await LoadDataAsync();
    }
    private void GoToInventory(int id)
    {
        Navigation.NavigateTo($"/inventories/{id}");
    }

    // ── Salesforce CRM ──────────────────────────────────────────────────────
    private bool _showCrmModal = false;
    private bool _crmSubmitting = false;
    private bool _crmSuccess = false;
    private string? _crmError;
    private string _crmFirstName = string.Empty;
    private string _crmLastName = string.Empty;
    private string _crmPhone = string.Empty;
    private string _crmCompany = string.Empty;
    private string _crmIndustry = string.Empty;
    private string _crmCountry = string.Empty;
    private string? _crmAccountId;
    private string? _crmContactId;

    private void OpenCrmModal()
    {
        _crmSuccess = false;
        _crmError = null;
        // Pre-fill email from current user
        var nameParts = _currentUserId != null
            ? (AuthStateProvider.GetAuthenticationStateAsync().Result.User.Identity?.Name ?? "")
                .Split(' ', 2)
            : Array.Empty<string>();
        _crmFirstName = nameParts.Length > 0 ? nameParts[0] : string.Empty;
        _crmLastName  = nameParts.Length > 1 ? nameParts[1] : string.Empty;
        _showCrmModal = true;
    }

    private async Task SubmitCrmAsync()
    {
        if (string.IsNullOrWhiteSpace(_crmFirstName) ||
            string.IsNullOrWhiteSpace(_crmLastName) ||
            string.IsNullOrWhiteSpace(_crmCompany))
        {
            _crmError = "First Name, Last Name and Company are required.";
            return;
        }

        _crmSubmitting = true;
        _crmError = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                     ?? authState.User.Identity?.Name
                     ?? string.Empty;

            var req = new InventoryApp.Web.Services.SalesforceContactRequest
            {
                FirstName = _crmFirstName.Trim(),
                LastName  = _crmLastName.Trim(),
                Email     = email,
                Phone     = _crmPhone.Trim(),
                Company   = _crmCompany.Trim(),
                Industry  = _crmIndustry,
                Country   = _crmCountry.Trim(),
            };

            (_crmAccountId, _crmContactId) =
                await SalesforceService.CreateAccountAndContactAsync(req);

            _crmSuccess = true;
        }
        catch (Exception ex)
        {
            _crmError = ex.Message;
        }
        finally
        {
            _crmSubmitting = false;
        }
    }
    // ────────────────────────────────────────────────────────────────────────
}