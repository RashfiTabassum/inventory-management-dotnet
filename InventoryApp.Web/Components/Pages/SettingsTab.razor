@rendermode InteractiveServer
@inject InventoryService InventoryService
@using System.Linq
@inject InventoryApp.Web.Services.CloudinaryService CloudinaryService
@inject IServiceProvider ServiceProvider
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager

@if (_inventory == null)
{
    <p>Loading...</p>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <div class="mb-3">
                <label class="form-label">Name *</label>
                <input class="form-control"
                       value="@_name"
                       @oninput="e => { _name = e.Value?.ToString() ?? string.Empty; MarkDirty(); }" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" rows="4"
                          @oninput="e => { _description = e.Value?.ToString() ?? string.Empty; MarkDirty(); }">@_description</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select class="form-select"
                        value="@_category"
                        @onchange="e => { _category = Enum.Parse<InventoryCategory>(e.Value?.ToString() ?? string.Empty); MarkDirty(); }">
                    @foreach (var cat in Enum.GetValues<InventoryCategory>())
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                           checked="@_isPublicWrite"
                           @onchange="e => { _isPublicWrite = (bool)(e.Value ?? false); MarkDirty(); }" />
                    <label class="form-check-label">
                        Public — all authenticated users can add items
                    </label>
                </div>
            </div>
           
            <div class="mb-3 position-relative">
                <label class="form-label">Tags <small class="text-muted">(comma separated)</small></label>
                <input class="form-control"
                       value="@_tags"
                       @oninput="HandleTagInput"
                       @onblur="HideTagSuggestions"
                       autocomplete="off" />
                @if (_tagSuggestions.Count > 0)
                {
                    <div class="position-absolute bg-white border rounded shadow-sm"
                         style="z-index:1000; width:100%; max-height:200px; overflow-y:auto;">
                        @foreach (var suggestion in _tagSuggestions)
                        {
                            <div class="px-3 py-2"
                                 style="cursor:pointer"
                                 @onmousedown="() => SelectTagSuggestion(suggestion)">
                                @suggestion
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="mb-3">
                <label class="form-label">Inventory Image</label>
                @if (!string.IsNullOrEmpty(_inventory.ImageUrl))
                {
                    <div class="mb-2">
                        <img src="@_inventory.ImageUrl"
                             style="max-width:300px; max-height:200px; object-fit:cover;"
                             class="img-thumbnail" />
                    </div>
                }
                <InputFile OnChange="HandleImageUpload"
                           accept="image/*"
                           class="form-control" />
                @if (_uploading)
                {
                    <small class="text-muted">Uploading...</small>
                }
            </div>

            @if (_statusMessage != null)
            {
                <div class="alert @(_saveError ? "alert-danger" : "alert-success")">
                    @_statusMessage
                </div>
            }

            @if (_isDirty)
            {
                <small class="text-muted">Unsaved changes...</small>
            }

            <hr />
            <h6>Odoo API Token</h6>
            <p class="text-muted small">
                Use this token to import inventory data into Odoo via the external API.
            </p>
            @if (!string.IsNullOrEmpty(_inventory?.ApiToken))
            {
                <div class="input-group mb-2" style="max-width:500px">
                    <input class="form-control form-control-sm font-monospace"
                           readonly value="@_inventory.ApiToken" id="apiTokenInput" />
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="CopyToken" title="Copy token">
                        📋
                    </button>
                </div>
                <div class="mb-2">
                    <small class="text-muted">
                        API URL: <code>@(NavigationManager.BaseUri)api/inventory/@_inventory.ApiToken</code>
                    </small>
                </div>
            }
            else
            {
                <p class="text-muted small">No token generated yet.</p>
            }
            <button class="btn btn-outline-primary btn-sm" @onclick="GenerateToken"
                    disabled="@_generatingToken">
                @(_generatingToken ? "Generating..." : (_inventory?.ApiToken == null ? "Generate Token" : "Regenerate Token"))
            </button>
            @if (_tokenCopied)
            {
                <small class="text-success ms-2">Copied!</small>
            }
        </div>
    </div>
}

@implements IAsyncDisposable

@code {
    [Parameter]
    public int InventoryId { get; set; }

    private InventoryApp.Data.Models.Inventory? _inventory;
    private string _name = string.Empty;
    private string _description = string.Empty;
    private InventoryCategory _category = InventoryCategory.Other;
    private bool _isPublicWrite = false;
    private bool _isDirty = false;
    private bool _saveError = false;
    private string? _statusMessage;
    private string _tags = string.Empty;

    private System.Timers.Timer? _autoSaveTimer;

    private DateTime _lastDirtyTime = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        _inventory = await InventoryService.GetByIdAsync(InventoryId);

        if (_inventory != null)
        {
            _name = _inventory.Name;
            _description = _inventory.Description;
            _category = _inventory.Category;
            _isPublicWrite = _inventory.IsPublicWrite;
            _tags = string.Join(", ", _inventory.Tags.Select(t => t.Name));
            // ApiToken is loaded with the inventory entity
        }

        _autoSaveTimer = new System.Timers.Timer(8000);
        _autoSaveTimer.AutoReset = true;
        _autoSaveTimer.Elapsed += async (s, e) => await AutoSaveAsync();
        _autoSaveTimer.Start();
    }

    private void MarkDirty()
    {
        _isDirty = true;
        _lastDirtyTime = DateTime.UtcNow;
    }

    private async Task AutoSaveAsync()
    {
        if (!_isDirty) return;
        if ((DateTime.UtcNow - _lastDirtyTime).TotalSeconds < 7) return;

        _isDirty = false;

        await InvokeAsync(async () =>
        {
            await SaveAsync();
            StateHasChanged();
        });
    }

    private async Task SaveAsync()
    {
        if (_inventory == null) return;
        if (string.IsNullOrWhiteSpace(_name)) return;

        _inventory.Name = _name.Trim();
        _inventory.Description = _description.Trim();
        _inventory.Category = _category;
        _inventory.IsPublicWrite = _isPublicWrite;

        var success = await InventoryService.UpdateAsync(_inventory);

        if (success)
        {
            _inventory.Version++;
            _isDirty = false;
            _saveError = false;
            _statusMessage = "Saved at " + DateTime.Now.ToString("HH:mm:ss");

            using var scope = ServiceProvider.CreateScope();
            var inventoryService = scope.ServiceProvider
                .GetRequiredService<InventoryService>();
            await inventoryService.SaveTagsAsync(InventoryId, _tags);
        }
        else
        {
            _saveError = true;
            _statusMessage = "Save failed — someone else modified this inventory. Reload to get latest version.";
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_autoSaveTimer != null)
        {
            _autoSaveTimer.Stop();
            _autoSaveTimer.Dispose();
        }

        if (_isDirty && (DateTime.UtcNow - _lastDirtyTime).TotalSeconds >= 2)
            await SaveAsync();
    }
    private bool _uploading = false;

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        if (file.Size > 5 * 1024 * 1024)
        {
            _statusMessage = "Image must be under 5MB.";
            _saveError = true;
            return;
        }

        _uploading = true;
        StateHasChanged();

        using var stream = file.OpenReadStream(5 * 1024 * 1024);
        var url = await CloudinaryService
            .UploadImageAsync(stream, file.Name);

        _uploading = false;

        if (url != null && _inventory != null)
        {
            _inventory.ImageUrl = url;
            await InventoryService.UpdateAsync(_inventory);
            _statusMessage = "Image uploaded successfully.";
            _saveError = false;
        }
        else
        {
            _statusMessage = "Image upload failed.";
            _saveError = true;
        }
    }
    private bool _generatingToken = false;
    private bool _tokenCopied = false;

    private async Task GenerateToken()
    {
        _generatingToken = true;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        var isAdmin = user.IsInRole("Admin");

        var token = await InventoryService.GenerateApiTokenAsync(InventoryId, userId, isAdmin);
        if (!string.IsNullOrEmpty(token) && _inventory != null)
            _inventory.ApiToken = token;

        _generatingToken = false;
    }

    private async Task CopyToken()
    {
        // Token is displayed in the input; just show a visual cue
        _tokenCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _tokenCopied = false;
        StateHasChanged();
    }

    private List<string> _tagSuggestions = new();

    private async Task HandleTagInput(ChangeEventArgs e)
    {
        _tags = e.Value?.ToString() ?? string.Empty;
        MarkDirty();

        var parts = _tags.Split(',');
        var lastPart = parts.Last().Trim();

        if (lastPart.Length >= 1)
        {
            using var scope = ServiceProvider.CreateScope();
            var inventoryService = scope.ServiceProvider
                .GetRequiredService<InventoryService>();

            var allTags = await inventoryService.GetTagCloudAsync();
            _tagSuggestions = allTags.Keys
                .Where(t => t.StartsWith(lastPart.ToLower())
                    && !parts.Take(parts.Length - 1)
                        .Select(p => p.Trim().ToLower())
                        .Contains(t))
                .Take(5)
                .ToList();
        }
        else
        {
            _tagSuggestions.Clear();
        }
    }

    private void SelectTagSuggestion(string tag)
    {
        var parts = _tags.Split(',').ToList();
        parts[parts.Count - 1] = " " + tag;
        _tags = string.Join(",", parts).TrimStart() + ", ";
        _tagSuggestions.Clear();
        MarkDirty();
    }

    private void HideTagSuggestions()
    {
        Task.Delay(200).ContinueWith(_ =>
            InvokeAsync(() =>
            {
                _tagSuggestions.Clear();
                StateHasChanged();
            }));
    }
}