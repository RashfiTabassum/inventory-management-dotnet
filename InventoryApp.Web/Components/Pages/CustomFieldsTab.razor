@rendermode InteractiveServer
@inject CustomFieldService CustomFieldService
@inject IJSRuntime JS
@implements IDisposable

@if (_fields == null)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary btn-sm"
                @onclick="() => _showAddForm = true">
            + Add Field
        </button>
    </div>

    @if (_showAddForm)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h6>New Field</h6>
                <div class="mb-2">
                    <label class="form-label">Title *</label>
                    <input class="form-control" @bind="_newTitle" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Description (shown as tooltip)</label>
                    <input class="form-control" @bind="_newDescription" />
                </div>
                <div class="mb-2">
                    <label class="form-label">Field Type</label>
                    <select class="form-select" @bind="_newFieldType">
                        @foreach (var type in Enum.GetValues<CustomFieldType>())
                        {
                            <option value="@type">@GetFieldTypeLabel(type)</option>
                        }
                    </select>
                </div>
                <div class="mb-2">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox"
                               @bind="_newShowInTable" />
                        <label class="form-check-label">
                            Show in items table
                        </label>
                    </div>
                </div>
                @if (_addError != null)
                {
                    <div class="alert alert-danger">@_addError</div>
                }
                <button class="btn btn-success btn-sm"
                        @onclick="HandleAddField">
                    Save Field
                </button>
                <button class="btn btn-secondary btn-sm ms-2"
                        @onclick="() => { _showAddForm = false; _addError = null; }">
                    Cancel
                </button>
            </div>
        </div>
    }

    @if (_fields.Count == 0)
    {
        <p class="text-muted">No custom fields defined yet.</p>
    }
    else
    {
        <p class="text-muted small">
            <i>Drag rows to reorder. Select rows and click Delete to remove fields.</i>
        </p>

        <div class="mb-2">
            <button class="btn btn-danger btn-sm"
                    @onclick="HandleDeleteSelected"
                    disabled="@(!_selectedFieldIds.Any())">
                Delete Selected
            </button>
            @if (_selectedFieldIds.Any())
            {
                <span class="text-muted ms-2 small">@_selectedFieldIds.Count selected</span>
            }
        </div>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th style="width:30px"></th>
                    <th style="width:40px">
                        <input type="checkbox"
                               checked="@(_fields.Count > 0 && _selectedFieldIds.Count == _fields.Count)"
                               @onchange="ToggleSelectAll" />
                    </th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Description</th>
                    <th>Show in Table</th>
                </tr>
            </thead>
            <tbody id="fields-sortable">
                @foreach (var field in _fields)
                {
                    <tr data-id="@field.Id"
                        style="cursor:grab"
                        class="@(_selectedFieldIds.Contains(field.Id) ? "table-active" : "")">
                        <td class="text-muted">⠿</td>
                        <td @onclick:stopPropagation="true">
                            <input type="checkbox"
                                   checked="@_selectedFieldIds.Contains(field.Id)"
                                   @onchange="() => ToggleSelect(field.Id)" />
                        </td>
                        <td>@field.Title</td>
                        <td>@GetFieldTypeLabel(field.FieldType)</td>
                        <td>@field.Description</td>
                        <td>
                            @if (field.ShowInTable)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_message != null)
    {
        <div class="alert alert-info mt-2">@_message</div>
    }
}

@code {
    [Parameter]
    public int InventoryId { get; set; }

    private List<CustomField>? _fields;
    private bool _showAddForm = false;
    private string _newTitle = string.Empty;
    private string _newDescription = string.Empty;
    private CustomFieldType _newFieldType = CustomFieldType.SingleLine;
    private bool _newShowInTable = true;
    private string? _addError;
    private string? _message;
    private DotNetObjectReference<CustomFieldsTab>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        await LoadFieldsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_fields != null && _fields.Count > 0)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "initSortable", "fields-sortable", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnFieldReordered(int oldIndex, int newIndex)
    {
        if (_fields == null) return;

        var field = _fields[oldIndex];
        _fields.RemoveAt(oldIndex);
        _fields.Insert(newIndex, field);

        for (int i = 0; i < _fields.Count; i++)
        {
            _fields[i].DisplayOrder = i + 1;
            await CustomFieldService.UpdateAsync(_fields[i]);
        }

        await LoadFieldsAsync();
        StateHasChanged();
    }

    private async Task LoadFieldsAsync()
    {
        _fields = await CustomFieldService.GetByInventoryAsync(InventoryId);
    }

    private async Task HandleAddField()
    {
        if (string.IsNullOrWhiteSpace(_newTitle))
        {
            _addError = "Title is required.";
            return;
        }

        var count = await CustomFieldService
            .GetFieldCountByTypeAsync(InventoryId, _newFieldType);

        if (count >= 3)
        {
            _addError = $"Maximum 3 fields of type " +
                $"{GetFieldTypeLabel(_newFieldType)} allowed.";
            return;
        }

        var field = new CustomField
            {
                Title = _newTitle.Trim(),
                Description = _newDescription.Trim(),
                FieldType = _newFieldType,
                ShowInTable = _newShowInTable,
                InventoryId = InventoryId
            };

        await CustomFieldService.CreateAsync(field);

        _newTitle = string.Empty;
        _newDescription = string.Empty;
        _newFieldType = CustomFieldType.SingleLine;
        _newShowInTable = true;
        _showAddForm = false;
        _addError = null;
        _message = "Field added successfully.";

        await LoadFieldsAsync();
    }


    private string GetFieldTypeLabel(CustomFieldType type)
    {
        return type switch
        {
            CustomFieldType.SingleLine => "Single Line Text",
            CustomFieldType.MultiLine => "Multi Line Text",
            CustomFieldType.Numeric => "Number",
            CustomFieldType.DocumentLink => "Document / Image Link",
            CustomFieldType.Boolean => "Checkbox (Yes/No)",
            _ => type.ToString()
        };
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
    private HashSet<int> _selectedFieldIds = new();

    private void ToggleSelect(int fieldId)
    {
        if (_selectedFieldIds.Contains(fieldId))
            _selectedFieldIds.Remove(fieldId);
        else
            _selectedFieldIds.Add(fieldId);
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        var all = (bool)(e.Value ?? false);
        if (all && _fields != null)
            _selectedFieldIds = _fields.Select(f => f.Id).ToHashSet();
        else
            _selectedFieldIds.Clear();
    }

    private async Task HandleDeleteSelected()
    {
        foreach (var id in _selectedFieldIds)
            await CustomFieldService.DeleteAsync(id);

        _selectedFieldIds.Clear();
        _message = "Selected fields deleted.";
        await LoadFieldsAsync();
    }
}