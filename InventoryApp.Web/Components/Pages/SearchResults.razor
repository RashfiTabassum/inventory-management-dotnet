@page "/search"
@rendermode InteractiveServer
@inject SearchService SearchService
@inject NavigationManager Navigation
@using InventoryApp.Data.Services

<PageTitle>Search — @_query</PageTitle>

<h4>Search Results for "@_query"</h4>

@if (_loading)
{
    <p>Searching...</p>
}
else if (_results == null)
{
    <p>Enter a search term above.</p>
}
else if (!_results.HasResults)
{
    <p class="text-muted">No results found for "@_query".</p>
}
else
{
    @if (_results.Inventories.Count > 0)
    {
        <h5 class="mt-3">Inventories (@_results.Inventories.Count)</h5>
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Owner</th>
                    <th>Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in _results.Inventories)
                {
                    <tr @onclick="() => GoToInventory(inv.Id)" style="cursor:pointer">
                        <td>@inv.Name</td>
                        <td>@inv.Category</td>
                        <td>@inv.Owner.Email</td>
                        <td>@inv.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (_results.Items.Count > 0)
    {
        <h5 class="mt-3">Items (@_results.Items.Count)</h5>
        <table class="table table-hover table-bordered">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Custom ID</th>
                    <th>Created By</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _results.Items)
                {
                    <tr @onclick="() => GoToItem(item.Id)" style="cursor:pointer">
                        <td>@item.Name</td>
                        <td>@item.CustomId</td>
                        <td>@item.CreatedBy.Email</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    // @using SR = InventoryApp.Data.Services.SearchResults
    [SupplyParameterFromQuery]
    public string? Q { get; set; }

    private string _query = string.Empty;
    private InventoryApp.Data.Services.SearchResults? _results;
    private bool _loading = false;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Q)) return;

        _query = Q;
        _loading = true;
        _results = null;

        _results = await SearchService.SearchAsync(_query);
        _loading = false;
    }
    private void GoToInventory(int id)
    {
        Navigation.NavigateTo($"/inventories/{id}");
    }

    private void GoToItem(int id)
    {
        Navigation.NavigateTo($"/items/{id}");
    }
}