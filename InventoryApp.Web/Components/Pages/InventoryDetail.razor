@page "/inventories/{Id:int}"
@rendermode InteractiveServer
@inject InventoryApp.Data.Services.InventoryService InventoryService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject InventoryApp.Web.Services.LocalizationService Loc

<PageTitle>@(_inventory?.Name ?? "Inventory")</PageTitle>

@if (_inventory == null)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>@_inventory.Name</h3>
        <span class="badge bg-secondary">@_inventory.Category</span>
    </div>
    @if (!string.IsNullOrEmpty(_inventory.Description))
    {
        <div class="mb-3">
            <MarkdownText Content="@_inventory.Description" />
        </div>
    }

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "items" ? "active" : "")"
                    @onclick='() => ActiveTab = "items"'>
                @Loc.Get("Items")
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "discussion" ? "active" : "")"
                    @onclick='() => ActiveTab = "discussion"'>
                @Loc.Get("Discussion")
            </button>
        </li>
        @if (_isOwnerOrAdmin)
        {
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "settings" ? "active" : "")"
                        @onclick='() => ActiveTab = "settings"'>
                    @Loc.Get("Settings")
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "fields" ? "active" : "")"
                        @onclick='() => ActiveTab = "fields"'>
                    @Loc.Get("CustomFields")
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "access" ? "active" : "")"
                        @onclick='() => ActiveTab = "access"'>
                    @Loc.Get("Access")
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "customid" ? "active" : "")"
                        @onclick='() => ActiveTab = "customid"'>
                    @Loc.Get("CustomID")
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(ActiveTab == "statistics" ? "active" : "")"
                        @onclick='() => ActiveTab = "statistics"'>
                    @Loc.Get("Statistics")
                </button>
            </li>
        }
    </ul>
    <!-- Tab Content -->
    @if (ActiveTab == "items")
    {
        <ItemsTab InventoryId="Id" IsOwnerOrAdmin="_isOwnerOrAdmin" />
    }
    else if (ActiveTab == "discussion")
    {
        <DiscussionTab InventoryId="Id" />
    }
    else if (ActiveTab == "settings")
    {
        <SettingsTab InventoryId="Id" />
    }
    else if (ActiveTab == "fields")
    {
        <CustomFieldsTab InventoryId="Id" />
    }
    else if (ActiveTab == "access")
    {
        <AccessTab InventoryId="Id" />
    }
    else if (ActiveTab == "customid")
    {
        <CustomIdTab InventoryId="Id" />
    }
    else if (ActiveTab == "statistics")
    {
        <StatisticsTab InventoryId="Id" />
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private InventoryApp.Data.Models.Inventory? _inventory;
    private string ActiveTab = "items";
    private bool _isOwnerOrAdmin = false;
    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _inventory = await InventoryService.GetByIdAsync(Id);

        if (_inventory == null)
        {
            Navigation.NavigateTo("/inventories");
            return;
        }

        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var user = authState.User;

        _currentUserId = user.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        var isAdmin = user.IsInRole("Admin");
        _isOwnerOrAdmin = isAdmin || _inventory.OwnerId == _currentUserId;
    }
}