@page "/admin"
@rendermode InteractiveServer
@inject AdminService AdminService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Admin Panel</PageTitle>

<AuthorizeView Roles="Admin">
    <Authorized>
        <h3>Admin Panel</h3>
        <p class="text-muted">User Management</p>

        @if (_users == null)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="mb-3 d-flex gap-2 flex-wrap">
                <button class="btn btn-warning btn-sm"
                        @onclick="HandleBlockSelected"
                        disabled="@(!_selectedIds.Any())">
                    Block Selected
                </button>
                <button class="btn btn-success btn-sm"
                        @onclick="HandleUnblockSelected"
                        disabled="@(!_selectedIds.Any())">
                    Unblock Selected
                </button>
                <button class="btn btn-outline-primary btn-sm"
                        @onclick="HandleAddAdminSelected"
                        disabled="@(!_selectedIds.Any())">
                    Make Admin
                </button>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="HandleRemoveAdminSelected"
                        disabled="@(!_selectedIds.Any())">
                    Remove Admin
                </button>
                <button class="btn btn-danger btn-sm"
                        @onclick="HandleDeleteSelected"
                        disabled="@(!_selectedIds.Any())">
                    Delete Selected
                </button>
                @if (_selectedIds.Any())
                {
                    <span class="text-muted align-self-center">
                        @_selectedIds.Count selected
                    </span>
                }
            </div>

            <table class="table table-hover table-bordered">
                <thead>
                    <tr>
                        <th style="width:40px">
                            <input type="checkbox"
                                   checked="@_allSelected"
                                   @onchange="ToggleSelectAll" />
                        </th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _users)
                    {
                        <tr @onclick="() => ToggleSelect(entry.User.Id)"
                            style="cursor:pointer"
                            class="@(_selectedIds.Contains(entry.User.Id) ? "table-active" : "")">
                            <td @onclick:stopPropagation="true">
                                <input type="checkbox"
                                       checked="@_selectedIds.Contains(entry.User.Id)"
                                       @onchange="() => ToggleSelect(entry.User.Id)" />
                            </td>
                            <td>
                                @entry.User.Email
                                @if (entry.User.Id == _currentUserId)
                                {
                                    <span class="badge bg-info ms-1">You</span>
                                }
                            </td>
                            <td>@string.Join(", ", entry.Roles)</td>
                            <td>
                                @if (entry.User.IsBlocked)
                                {
                                    <span class="badge bg-danger">Blocked</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        @if (_message != null)
        {
            <div class="alert alert-info mt-3">@_message</div>
        }
    </Authorized>
    <NotAuthorized>
        <p>Access denied. Admins only.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<UserWithRoles>? _users;
    private string? _currentUserId;
    private string? _message;
    private HashSet<string> _selectedIds = new();
    private bool _allSelected = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider
            .GetAuthenticationStateAsync();
        var user = authState.User;

        _currentUserId = user.FindFirst(
            System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!user.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/");
            return;
        }

        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _users = await AdminService.GetAllUsersAsync();
        _selectedIds.Clear();
        _allSelected = false;
    }

    private void ToggleSelect(string userId)
    {
        if (_selectedIds.Contains(userId))
            _selectedIds.Remove(userId);
        else
            _selectedIds.Add(userId);

        _allSelected = _users != null &&
            _users.All(u => _selectedIds.Contains(u.User.Id));
    }

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        _allSelected = (bool)(e.Value ?? false);

        if (_allSelected && _users != null)
            _selectedIds = _users
                .Select(u => u.User.Id).ToHashSet();
        else
            _selectedIds.Clear();
    }

    private async Task HandleBlockSelected()
    {
        foreach (var id in _selectedIds
            .Where(id => id != _currentUserId))
            await AdminService.BlockUserAsync(id);

        _message = "Selected users blocked.";
        await LoadUsersAsync();
    }

    private async Task HandleUnblockSelected()
    {
        foreach (var id in _selectedIds
            .Where(id => id != _currentUserId))
            await AdminService.UnblockUserAsync(id);

        _message = "Selected users unblocked.";
        await LoadUsersAsync();
    }

    private async Task HandleAddAdminSelected()
    {
        foreach (var id in _selectedIds)
            await AdminService.AddAdminRoleAsync(id);

        _message = "Admin role added to selected users.";
        await LoadUsersAsync();
    }

    private async Task HandleRemoveAdminSelected()
    {
        foreach (var id in _selectedIds)
            await AdminService.RemoveAdminRoleAsync(id);

        _message = "Admin role removed from selected users.";
        await LoadUsersAsync();
    }

    private async Task HandleDeleteSelected()
    {
        foreach (var id in _selectedIds
            .Where(id => id != _currentUserId))
            await AdminService.DeleteUserAsync(id);

        _message = "Selected users deleted.";
        await LoadUsersAsync();
    }
}