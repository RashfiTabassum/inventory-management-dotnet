@rendermode InteractiveServer
@inject IJSRuntime JS

<button class="btn btn-sm btn-outline-secondary"
        @onclick="ToggleTheme"
        title="Toggle dark/light mode">
    @(_isDark ? "☀️" : "🌙")
</button>

