@code {
    private bool _isDark = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>(
                "themeHelper.getCookie", "theme");
            _isDark = theme == "dark";
            await JS.InvokeVoidAsync("themeHelper.applyTheme", _isDark);
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("themeHelper.setCookie",
            "theme", _isDark ? "dark" : "light");
        await JS.InvokeVoidAsync("themeHelper.applyTheme", _isDark);
    }
}