@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        @* <div class="top-row px-4 d-flex justify-content-between align-items-center"> *@
        @*     <SearchBox /> *@

        @*     <AuthorizeView> *@
        @*         <Authorized> *@
        @*             <span class="me-3">Hello, @context.User.Identity!.Name</span> *@
        @*             <a href="/account/logout" class="btn btn-sm btn-outline-secondary"> *@
        @*                 Logout *@
        @*             </a> *@
        @*         </Authorized> *@
        @*         <NotAuthorized> *@
        @*             <a href="/account/login" class="btn btn-sm btn-outline-primary"> *@
        @*                 Login *@
        @*             </a> *@
        @*         </NotAuthorized> *@
        @*     </AuthorizeView> *@
        @* </div> *@
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <SearchBox />
            <div class="d-flex align-items-center gap-3">
                <ThemeSwitcher />
                <LanguageSwitcher />
                <AuthorizeView>
                    <Authorized>
                        <span class="me-3">Hello, @context.User.Identity!.Name</span>
                        <a href="/account/logout" class="btn btn-sm btn-outline-secondary">
                            Logout
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/account/login" class="btn btn-sm btn-outline-primary">
                            Login
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private string _searchQuery = string.Empty;

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            ExecuteSearch();
    }

    private void ExecuteSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        Navigation.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
    }

}